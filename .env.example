# ----- Identity -----
ZAX_FOUNDER_NAME=Bhupen

# ----- Intelligence core ---------------------------------------------------
# Everything here is OPTIONAL — providers are normally configured live from the
# Settings panel in the UI. Env vars below act as fallbacks.
#
# Default behaviour (ZAX_PROVIDER=auto): if the `claude` CLI is installed and
# logged in (`claude login`), Zax runs on your ANTHROPIC SUBSCRIPTION — no API
# key, no metered billing. Otherwise the first configured API key wins, and
# with nothing configured Zax runs on a demo mock core.
#
# ZAX_PROVIDER=auto   # auto | claude-cli | anthropic | openai | google | openrouter |
#                     # groq | mistral | deepseek | xai | together | ollama | custom | mock
# ZAX_MODEL=          # override the active provider's default model

# API keys (only needed for the provider you use; all settable in the UI too)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
# TOGETHER_API_KEY=...

# Local models
# OLLAMA_URL=http://localhost:11434

# ----- Server -----
# ZAX_HOST=127.0.0.1
# ZAX_PORT=8777

# ----- Org policy (the Paperclip side) -----
# ZAX_HEARTBEAT_SECONDS=20
# ZAX_MAX_HEADCOUNT=8
# ZAX_FIRE_THRESHOLD=50        # perf % below which Zax fires
# ZAX_MIN_TASKS_BEFORE_FIRE=3
# ZAX_DEFAULT_TOKEN_BUDGET=250000

# ----- Agent tools (the Odysseus side) -----
# ZAX_ALLOW_SHELL=0            # 1 = agents may run shell commands in their workspace

# ----- Zax voice (deep TTS profile) -----
# ZAX_TTS_VOICE=en-US-ChristopherNeural
# ZAX_TTS_PITCH=-18Hz
# ZAX_TTS_RATE=-6%

# ----- Cloud deploy (Railway/Render/Fly) -----
# ZAX_HOST=0.0.0.0            # set by the Dockerfile; bind all interfaces
# ZAX_DATA_DIR=/data          # mount a persistent volume here for zax.db
# ZAX_ACCESS_PASSWORD=        # REQUIRED for public deploys — HTTP Basic password gate
# (PORT is injected by the host; config.py honours it automatically)
# ZAX_DATABASE / Supabase Postgres (blank = local SQLite). When set, Zax stores
# everything in Postgres. Get it from Supabase → Connect → Session pooler.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@<host>:5432/postgres
